{
	"name": "lavender",
	"description": "A gentle companion for your personal wellness journey. Track, reflect, and bloom at your own rhythm.",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "vitest run && vite build && wrangler deploy",
		"preview": "vite preview",
		"db:migrate:local": "wrangler d1 migrations apply lavender-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply lavender-db --remote",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"seed": "tsx scripts/seed.ts",
		"db:user-count": "tsx scripts/user-count.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@libpdf/core": "^0.3.4",
		"@lucide/svelte": "^1.7.0",
		"chart.js": "^4.5.1",
		"date-fns": "^4.1.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260405.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.56.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^22.10.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"jsdom": "^29.0.2",
		"prettier": "^3.4.0",
		"prettier-plugin-svelte": "^3.3.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.1.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"typescript-eslint": "^8.58.0",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"wrangler": "^4.81.0"
	}
}
