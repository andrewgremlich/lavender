{
	"name": "lavender",
	"description": "A gentle companion for your personal wellness journey. Track, reflect, and bloom at your own rhythm.",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "vite build && wrangler deploy",
		"preview": "vite preview",
		"db:migrate:local": "wrangler d1 migrations apply lavender-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply lavender-db --remote",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"seed": "tsx scripts/seed.ts",
		"db:user-count": "tsx scripts/user-count.ts",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@lucide/svelte": "^1.3.0",
		"chart.js": "^4.5.1",
		"date-fns": "^4.1.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260401.1",
		"@eslint/js": "^9.39.4",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.15.0",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@types/node": "^22.10.0",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.46.0",
		"globals": "^15.14.0",
		"prettier": "^3.4.0",
		"prettier-plugin-svelte": "^3.3.0",
		"svelte": "^5.16.0",
		"svelte-check": "^4.1.0",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^5.4.0",
		"vitest": "^2.1.0",
		"wrangler": "^4.79.0"
	}
}
