{
	"name": "lavender",
	"description": "A gentle companion for your personal wellness journey. Track, reflect, and bloom at your own rhythm.",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "vitest run && vite build && wrangler deploy",
		"preview": "vite preview",
		"db:migrate:local": "wrangler d1 migrations apply lavender-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply lavender-db --remote",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"seed": "tsx scripts/seed.ts",
		"seed:demo": "tsx scripts/seed-demo.ts",
		"db:user-count": "tsx scripts/user-count.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"knip": "knip"
	},
	"dependencies": {
		"@fontsource/merriweather": "^5.2.11",
		"@fontsource/merriweather-sans": "^5.2.7",
		"@libpdf/core": "^0.3.4",
		"@lucide/svelte": "^1.14.0",
		"chart.js": "^4.5.1",
		"date-fns": "^4.1.0",
		"svelte-i18n": "^4.0.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260429.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/node": "^25.6.0",
		"eslint": "^10.2.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.5.0",
		"jsdom": "^29.1.0",
		"knip": "^6.9.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.1",
		"vite": "^8.0.10",
		"vitest": "^4.1.5",
		"wrangler": "^4.86.0"
	}
}
