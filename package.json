{
	"name": "lavender",
	"description": "A gentle companion for your personal wellness journey. Track, reflect, and bloom at your own rhythm.",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "vite build && wrangler deploy",
		"preview": "vite preview",
		"db:migrate:local": "wrangler d1 migrations apply lavender-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply lavender-db --remote",
		"check": "tsc --noEmit && pnpx @biomejs/biome check --write",
		"seed": "npx tsx scripts/seed.ts",
		"db:user-count": "npx tsx scripts/user-count.ts",
		"test": "vitest"
	},
	"dependencies": {
		"@types/node": "^25.5.0",
		"chart.js": "^4.5.1",
		"date-fns": "^4.1.0",
		"hono": "^4.12.9",
		"lucide": "^0.577.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@cloudflare/vite-plugin": "^1.30.3",
		"@cloudflare/workers-types": "^4.20260401.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.3",
		"vitest": "^4.1.2",
		"wrangler": "^4.79.0"
	}
}
