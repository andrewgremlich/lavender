{
  "name": "lavendar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "deploy": "vite build && wrangler deploy",
    "preview": "vite preview",
    "db:migrate:local": "wrangler d1 execute lavendar-db --local --file=src/worker/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute lavendar-db --remote --file=src/worker/db/schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "chart.js": "^4.5.1",
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@cloudflare/workers-types": "^4.20260317.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "wrangler": "^4.75.0"
  }
}
