{
	"name": "lavendar",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"deploy": "vite build && wrangler deploy",
		"preview": "vite preview",
		"db:migrate:local": "wrangler d1 execute lavendar-db --local --file=src/worker/db/schema.sql",
		"db:migrate:remote": "wrangler d1 execute lavendar-db --remote --file=src/worker/db/schema.sql",
		"check": "tsc --noEmit && pnpx @biomejs/biome check --write",
		"seed": "npx tsx scripts/seed.ts",
		"test": "vitest"
	},
	"dependencies": {
		"@types/node": "^25.5.0",
		"chart.js": "^4.5.1",
		"hono": "^4.12.8",
		"lucide": "^0.577.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@cloudflare/vite-plugin": "^1.30.0",
		"@cloudflare/workers-types": "^4.20260317.1",
		"typescript": "^5.9.3",
		"vite": "^8.0.1",
		"vitest": "^4.1.1",
		"wrangler": "^4.76.0"
	}
}
